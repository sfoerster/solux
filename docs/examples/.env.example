# Solux secrets — source this file before starting the worker:
#   source ~/.config/solux/.env && solux worker start
#
# NEVER commit this file to version control.

# ── Use Case 2: Morning News Digest ──────────────────────────────────────────
export SLACK_WEBHOOK_URL=""           # https://hooks.slack.com/services/...

# ── Use Case 3: PDF → Obsidian ───────────────────────────────────────────────
export OBSIDIAN_VAULT_PATH="$HOME/Documents/MyVault"

# ── Use Case 4: Email Triage ─────────────────────────────────────────────────
export IMAP_HOST=""                   # e.g. imap.gmail.com
export IMAP_USER=""                   # e.g. you@gmail.com
export IMAP_PASSWORD=""               # App password, not your account password

# ── Use Case 5: Article Index ────────────────────────────────────────────────
# (reuses OBSIDIAN_VAULT_PATH from above)

# ── Use Case 6: Distributed Pipeline — Node A ────────────────────────────────
export GPU_NODE_URL=""                # e.g. http://192.168.1.50:8765
export GPU_NODE_TOKEN=""              # Bearer token configured on Node B

# ── Use Case 6: Distributed Pipeline — Node B ────────────────────────────────
export NODE_A_CALLBACK_URL=""         # e.g. http://192.168.1.10:8765/api/trigger/ingest_done
